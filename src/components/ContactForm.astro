---
// Replace YOUR_FORM_ID with your actual Formspree form ID
const formspreeEndpoint = 'https://formspree.io/f/YOUR_FORM_ID';
---

<form
  action={formspreeEndpoint}
  method="POST"
  class="space-y-6"
  id="contact-form"
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="relative">
      <label for="name" class="block text-sm font-sans font-medium text-warm-dark mb-2 tracking-wide uppercase">
        Full Name
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="form-field"
        placeholder="Your full name"
      />
    </div>

    <div class="relative">
      <label for="email" class="block text-sm font-sans font-medium text-warm-dark mb-2 tracking-wide uppercase">
        Email Address
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="form-field"
        placeholder="you@email.com"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="relative">
      <label for="phone" class="block text-sm font-sans font-medium text-warm-dark mb-2 tracking-wide uppercase">
        Phone Number
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        class="form-field"
        placeholder="(253) 555-0123"
      />
    </div>

    <div class="relative">
      <label for="address" class="block text-sm font-sans font-medium text-warm-dark mb-2 tracking-wide uppercase">
        Home Address
      </label>
      <input
        type="text"
        id="address"
        name="address"
        class="form-field"
        placeholder="City, State"
      />
    </div>
  </div>

  <div class="relative">
    <label for="spaces" class="block text-sm font-sans font-medium text-warm-dark mb-2 tracking-wide uppercase">
      Space(s) Needing Help
    </label>
    <input
      type="text"
      id="spaces"
      name="spaces"
      class="form-field"
      placeholder="e.g. Kitchen, master closet, garage"
    />
  </div>

  <div class="relative">
    <label for="goals" class="block text-sm font-sans font-medium text-warm-dark mb-2 tracking-wide uppercase">
      Brief Description of Your Goals
    </label>
    <textarea
      id="goals"
      name="goals"
      rows="4"
      class="form-field resize-none"
      placeholder="Tell me about your space and what you'd like to achieve..."
    ></textarea>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="relative">
      <label for="preferred-time" class="block text-sm font-sans font-medium text-warm-dark mb-2 tracking-wide uppercase">
        Preferred Session Time
      </label>
      <select id="preferred-time" name="preferred-time" class="form-field">
        <option value="" disabled selected>Select a time preference</option>
        <option value="morning">Morning (8am - 12pm)</option>
        <option value="afternoon">Afternoon (12pm - 4pm)</option>
        <option value="evening">Evening (4pm - 7pm)</option>
        <option value="flexible">I'm flexible</option>
      </select>
    </div>

    <div class="relative">
      <label for="referral" class="block text-sm font-sans font-medium text-warm-dark mb-2 tracking-wide uppercase">
        How Did You Hear About Us?
      </label>
      <select id="referral" name="referral" class="form-field">
        <option value="" disabled selected>Select one</option>
        <option value="instagram">Instagram</option>
        <option value="google">Google Search</option>
        <option value="friend">Friend or Family</option>
        <option value="nextdoor">Nextdoor</option>
        <option value="other">Other</option>
      </select>
    </div>
  </div>

  <div class="pt-4">
    <button
      type="submit"
      class="w-full md:w-auto inline-flex items-center justify-center font-sans font-semibold tracking-wide uppercase rounded-full transition-all duration-400 relative overflow-hidden group bg-terracotta text-cream hover:bg-terracotta-dark hover:shadow-xl hover:shadow-terracotta/20 px-10 py-4 text-base"
    >
      <span class="relative z-10">Start My Peaceful Home Plan</span>
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent translate-x-[-200%] group-hover:translate-x-[200%] transition-transform duration-700"></div>
    </button>
  </div>
</form>

<script>
  function initForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = btn.querySelector('span')!.textContent;
      btn.querySelector('span')!.textContent = 'Sending...';
      btn.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (response.ok) {
          btn.querySelector('span')!.textContent = 'Message Sent!';
          btn.classList.remove('bg-terracotta', 'hover:bg-terracotta-dark');
          btn.classList.add('bg-sage');
          form.reset();
          setTimeout(() => {
            btn.querySelector('span')!.textContent = originalText;
            btn.classList.remove('bg-sage');
            btn.classList.add('bg-terracotta', 'hover:bg-terracotta-dark');
            btn.disabled = false;
          }, 3000);
        } else {
          throw new Error('Form submission failed');
        }
      } catch {
        btn.querySelector('span')!.textContent = 'Something went wrong — please try again';
        btn.disabled = false;
        setTimeout(() => {
          btn.querySelector('span')!.textContent = originalText;
        }, 3000);
      }
    });
  }

  initForm();
  document.addEventListener('astro:after-swap', initForm);
</script>

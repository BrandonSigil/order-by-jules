---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ProcessStep from '../components/ProcessStep.astro';
import CTASection from '../components/CTASection.astro';
import julesPhoto from '../assets/jules.png';
import clutterPhoto from '../assets/clutter.jpg';
import organizedDrawer from '../assets/oragnized-drawer.jpg';
---

<Layout title="Home">

  <!-- ===== HERO ===== -->
  <section class="relative flex items-center justify-center overflow-hidden bg-cream">

    <!-- Warm light atmosphere — layered gradients, no hard shapes -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">

      <!-- Layer 1: Wide warm band across the bottom -->
      <div class="absolute inset-x-0 bottom-0 h-[60%] opacity-0 animate-glow-in"
        style="background: linear-gradient(to top, rgba(245, 213, 160, 0.35), rgba(245, 213, 160, 0.1) 50%, transparent 100%);"
      ></div>

      <!-- Layer 2: Large diffused radial warmth from bottom-center -->
      <div class="absolute inset-x-0 bottom-0 h-full opacity-0 animate-glow-in" style="animation-delay: 0.2s;">
        <div class="absolute bottom-0 left-1/2 w-[140vw] md:w-[100vw] aspect-square" style="transform: translate(-50%, 60%);">
          <div class="w-full h-full rounded-full"
            style="background: radial-gradient(circle, rgba(232, 184, 109, 0.2) 0%, rgba(245, 213, 160, 0.12) 30%, transparent 65%);"
          ></div>
        </div>
      </div>

      <!-- Layer 3: Tighter warm core — the brightest part of the "light source" -->
      <div class="absolute inset-x-0 bottom-0 h-full opacity-0 animate-glow-in" style="animation-delay: 0.5s;">
        <div class="absolute bottom-0 left-1/2 w-[90vw] md:w-[60vw] aspect-square" style="transform: translate(-50%, 55%);">
          <div class="w-full h-full rounded-full animate-glow-breathe"
            style="background: radial-gradient(circle, rgba(232, 184, 109, 0.25) 0%, rgba(245, 213, 160, 0.1) 35%, transparent 60%);"
          ></div>
        </div>
      </div>

      <!-- Layer 4: Subtle light rays via conic gradient — barely visible, atmospheric -->
      <div class="absolute inset-x-0 bottom-0 h-full opacity-0 animate-glow-in" style="animation-delay: 0.8s;">
        <div class="absolute bottom-0 left-1/2 w-[120vw] md:w-[80vw] aspect-square" style="transform: translate(-50%, 50%);">
          <div class="w-full h-full"
            style="
              background: conic-gradient(
                from 180deg,
                transparent 0deg,
                rgba(245, 213, 160, 0.06) 8deg,
                transparent 16deg,
                transparent 28deg,
                rgba(232, 184, 109, 0.05) 34deg,
                transparent 40deg,
                transparent 55deg,
                rgba(245, 213, 160, 0.07) 62deg,
                transparent 70deg,
                transparent 82deg,
                rgba(232, 184, 109, 0.04) 88deg,
                transparent 95deg,
                transparent 108deg,
                rgba(245, 213, 160, 0.06) 114deg,
                transparent 121deg,
                transparent 135deg,
                rgba(232, 184, 109, 0.05) 140deg,
                transparent 147deg,
                transparent 160deg,
                rgba(245, 213, 160, 0.06) 166deg,
                transparent 173deg,
                transparent 180deg
              );
              mask-image: radial-gradient(circle, white 0%, transparent 65%);
              -webkit-mask-image: radial-gradient(circle, white 0%, transparent 65%);
            "
          ></div>
        </div>
      </div>

    </div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center pt-8 pb-14 md:pt-10 md:pb-16">
      <div class="mb-6 opacity-0 animate-fade-up" style="animation-delay: 0.3s;">
        <span class="inline-block font-cormorant text-lg md:text-xl italic text-warm tracking-wide">
          Order by Jules
        </span>
      </div>

      <h1 class="font-playfair text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-warm-dark leading-[1.1] mb-6 opacity-0 animate-fade-up" style="animation-delay: 0.5s;">
        There Is <em class="font-cormorant italic text-terracotta not-italic">Peace</em><br class="hidden sm:block" />
        on the Other Side<br class="hidden sm:block" />
        of Overwhelm.
      </h1>

      <p class="font-sans text-lg md:text-xl text-warm max-w-2xl mx-auto mb-10 opacity-0 animate-fade-up" style="animation-delay: 0.7s;">
        Decluttering and home organization for overwhelmed moms, busy women, and families preparing for life transitions.
      </p>

      <div class="opacity-0 animate-fade-up" style="animation-delay: 0.9s;">
        <Button href="/contact#contact-form" variant="primary" size="lg">
          Book Your Free Consultation
        </Button>
      </div>
    </div>

  </section>

  <!-- ===== SECTION 1 — THE PROBLEM ===== -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <h2 class="font-playfair text-3xl md:text-5xl text-warm-dark leading-tight mb-8 reveal">
            Feeling <em class="font-cormorant italic text-terracotta not-italic">Overwhelmed</em> in Your Own Home?
          </h2>

          <div class="space-y-4 mb-10">
            <p class="text-lg text-warm reveal stagger-1">Maybe the clutter keeps piling up.</p>
            <p class="text-lg text-warm reveal stagger-2">Maybe you don't know where to start.</p>
            <p class="text-lg text-warm reveal stagger-3">Maybe you're preparing to move or downsize.</p>
            <p class="text-lg text-warm reveal stagger-4">Maybe you feel embarrassed inviting people over.</p>
          </div>

          <div class="space-y-2 mb-8 reveal stagger-5">
            <p class="text-lg text-warm-dark font-medium">You don't need judgment.</p>
            <p class="text-lg text-warm-dark font-medium">You don't need perfection.</p>
          </div>

          <div class="reveal stagger-6">
            <div class="gold-rule !mx-0 mb-4"></div>
            <p class="font-cormorant text-2xl md:text-3xl italic text-terracotta leading-relaxed">
              You need clarity, momentum, and someone who sees hope in your space.
            </p>
          </div>
        </div>

        <div class="reveal-right">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-xl shadow-warm-dark/10">
            <Image
              src={clutterPhoto}
              alt="A cluttered coffee table — the kind of overwhelm we help with"
              class="w-full h-full object-cover"
              widths={[400, 600, 800]}
              sizes="(max-width: 1024px) 100vw, 50vw"
              quality={60}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider variant="wave2" toColor="#FBF7F2" />

  <!-- ===== SECTION 2 — THE SOLUTION ===== -->
  <section class="bg-cream py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Text -->
        <div class="reveal-left">
          <span class="font-cormorant text-lg italic text-gold mb-2 block">The solution</span>
          <h2 class="font-playfair text-3xl md:text-5xl text-warm-dark leading-tight mb-6">
            Meet <em class="font-cormorant italic text-terracotta not-italic">Order by Jules</em>
          </h2>

          <div class="space-y-4 text-lg text-warm leading-relaxed">
            <p>
              I help women and families reclaim their homes through efficient, joy-filled organizing sessions.
            </p>
            <p>
              Together, we declutter what no longer serves you, create simple systems that make sense for your real life, and restore peace to the spaces you use every day.
            </p>
            <p>
              I bring strength, energy, and quick decision-making into spaces that feel heavy and overwhelming.
            </p>
          </div>

          <div class="mt-8 space-y-1 text-warm-dark font-medium text-lg">
            <p>No shame.</p>
            <p>No chaos.</p>
            <p class="font-cormorant text-2xl italic text-terracotta">Just steady progress toward peace.</p>
          </div>

          <div class="mt-10">
            <Button href="/about" variant="outline" size="md">
              Learn More About Jules
            </Button>
          </div>
        </div>

        <!-- Image placeholder -->
        <div class="reveal-right">
          <div class="relative">
            <div class="aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl shadow-warm-dark/10">
              <Image
                src={julesPhoto}
                alt="Jules and her family"
                class="w-full h-full object-cover"
                widths={[400, 600, 800]}
                sizes="(max-width: 1024px) 100vw, 50vw"
                quality={60}
              />
            </div>
            <!-- Decorative offset element -->
            <div class="absolute -bottom-4 -right-4 w-full h-full rounded-2xl border-2 border-gold/30 -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider variant="wave3" toColor="#FFFFFF" />

  <!-- ===== SECTION 3 — HOW IT WORKS ===== -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="font-cormorant text-lg italic text-gold mb-2 block reveal">How it works</span>
        <h2 class="font-playfair text-3xl md:text-5xl text-warm-dark leading-tight mb-8 reveal stagger-1">
          A Simple <em class="font-cormorant italic text-terracotta not-italic">3-Step</em> Process
        </h2>
        <div class="mx-auto max-w-xs aspect-[3/2] rounded-xl overflow-hidden shadow-lg shadow-warm-dark/10 reveal stagger-2">
          <Image
            src={organizedDrawer}
            alt="A beautifully organized drawer with neatly folded clothes"
            class="w-full h-full object-cover"
            widths={[300, 500]}
            sizes="320px"
            quality={60}
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
        <ProcessStep
          number={1}
          title="Free Consultation"
          description="We walk through your space, clarify your goals, and create a plan that fits your timeline and budget."
        />
        <ProcessStep
          number={2}
          title="Declutter + Organize"
          description="We work side-by-side to simplify, sort, and build functional systems. I guide decision-making and handle the heavy lifting."
        />
        <ProcessStep
          number={3}
          title="Enjoy Your Peace"
          description="You experience a calm, functional space that supports your daily life — not stresses it."
          isLast={true}
        />
      </div>

      <div class="text-center mt-16 reveal">
        <Button href="/contact#contact-form" variant="primary" size="lg">
          Schedule My Consultation
        </Button>
      </div>
    </div>
  </section>

  <SectionDivider variant="wave2" toColor="#FBF7F2" />

  <!-- ===== SECTION 4 — INSTAGRAM FEED ===== -->
  <section class="bg-cream py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="font-cormorant text-lg italic text-gold mb-2 block reveal">Follow along</span>
        <h2 class="font-playfair text-3xl md:text-5xl text-warm-dark leading-tight mb-4 reveal stagger-1">
          On <em class="font-cormorant italic text-terracotta not-italic">Instagram</em>
        </h2>
        <a
          href="https://instagram.com/order_by_jules"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block font-sans text-terracotta hover:text-terracotta-dark transition-colors text-lg reveal stagger-2"
        >
          @order_by_jules
        </a>
      </div>

      <div id="instagram-feed" class="reveal stagger-3">
        <script src="https://elfsightcdn.com/platform.js" async></script>
        <div class="elfsight-app-22c1ff65-0a84-4ea3-b326-76a72d613f4e" data-elfsight-app-lazy></div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 5 — FINAL CTA ===== -->
  <CTASection
    headline="Ready to Reclaim Your Space?"
    subtext="There is hope for your home. Let's restore it together."
    buttonText="Book Your Free Consultation"
    buttonHref="/contact#contact-form"
    variant="warm"
  />

</Layout>
